From 2dda1ea952fd4eef35f2d397c9667e73e6d06615 Mon Sep 17 00:00:00 2001
From: Jonas Gorski <jonas.gorski@bisdn.de>
Date: Mon, 2 Dec 2024 12:48:22 +0100
Subject: [PATCH] BRPORT_LOCKED

Signed-off-by: Jonas Gorski <jonas.gorski@bisdn.de>
---
 src/libsystemd/sd-netlink/netlink-types-rtnl.c | 1 +
 src/network/networkd-network-gperf.gperf       | 1 +
 src/network/networkd-network.c                 | 1 +
 src/network/networkd-network.h                 | 1 +
 src/network/networkd-setlink.c                 | 6 ++++++
 5 files changed, 10 insertions(+)

diff --git a/src/libsystemd/sd-netlink/netlink-types-rtnl.c b/src/libsystemd/sd-netlink/netlink-types-rtnl.c
index 167bbc5ccfc6..2b3b69839c75 100644
--- a/src/libsystemd/sd-netlink/netlink-types-rtnl.c
+++ b/src/libsystemd/sd-netlink/netlink-types-rtnl.c
@@ -483,6 +483,8 @@ static const struct NLType rtnl_bridge_port_types[] = {
         [IFLA_BRPORT_MRP_IN_OPEN]           = { .type = NETLINK_TYPE_U8 },
         [IFLA_BRPORT_MCAST_EHT_HOSTS_LIMIT] = { .type = NETLINK_TYPE_U32 },
         [IFLA_BRPORT_MCAST_EHT_HOSTS_CNT]   = { .type = NETLINK_TYPE_U32 },
+	[IFLA_BRPORT_LOCKED]                = { .type = NETLINK_TYPE_U8 },
+	[IFLA_BRPORT_MAB]                = { .type = NETLINK_TYPE_U8 },
 };
 
 static const NLTypeSystemUnionElement rtnl_link_info_slave_data_type_systems[] = {
diff --git a/src/network/networkd-network-gperf.gperf b/src/network/networkd-network-gperf.gperf
index 4c3bf97311d4..455f0bb04f15 100644
--- a/src/network/networkd-network-gperf.gperf
+++ b/src/network/networkd-network-gperf.gperf
@@ -315,6 +315,7 @@ Bridge.MulticastFlood,                       config_parse_tristate,
 Bridge.MulticastToUnicast,                   config_parse_tristate,                                    0,                             offsetof(Network, multicast_to_unicast)
 Bridge.NeighborSuppression,                  config_parse_tristate,                                    0,                             offsetof(Network, neighbor_suppression)
 Bridge.Learning,                             config_parse_tristate,                                    0,                             offsetof(Network, learning)
+Bridge.Locked,                               config_parse_tristate,                                    0,                             offsetof(Network, locked)
 Bridge.ProxyARP,                             config_parse_tristate,                                    0,                             offsetof(Network, bridge_proxy_arp)
 Bridge.ProxyARPWiFi,                         config_parse_tristate,                                    0,                             offsetof(Network, bridge_proxy_arp_wifi)
 Bridge.Priority,                             config_parse_bridge_port_priority,                        0,                             offsetof(Network, priority)
diff --git a/src/network/networkd-network.c b/src/network/networkd-network.c
index efdedfaa1bfd..5650a9f61b1a 100644
--- a/src/network/networkd-network.c
+++ b/src/network/networkd-network.c
@@ -443,6 +443,7 @@ int network_load_one(Manager *manager, OrderedHashmap **networks, const char *fi
                 .multicast_to_unicast = -1,
                 .neighbor_suppression = -1,
                 .learning = -1,
+                .locked = -1,
                 .bridge_proxy_arp = -1,
                 .bridge_proxy_arp_wifi = -1,
                 .priority = LINK_BRIDGE_PORT_PRIORITY_INVALID,
diff --git a/src/network/networkd-network.h b/src/network/networkd-network.h
index f7eb37acedaf..4d9054c4a4a9 100644
--- a/src/network/networkd-network.h
+++ b/src/network/networkd-network.h
@@ -251,6 +251,7 @@ struct Network {
         int multicast_to_unicast;
         int neighbor_suppression;
         int learning;
+        int locked;
         int bridge_proxy_arp;
         int bridge_proxy_arp_wifi;
         uint32_t cost;
diff --git a/src/network/networkd-setlink.c b/src/network/networkd-setlink.c
index 1ab58a5bd214..6721796b8a7c 100644
--- a/src/network/networkd-setlink.c
+++ b/src/network/networkd-setlink.c
@@ -388,6 +388,12 @@ static int link_configure(
                                 return log_link_debug_errno(link, r, "Could not append IFLA_BRPORT_COST attribute: %m");
                 }
 
+                if (link->network->locked >= 0) {
+                        r = sd_netlink_message_append_u8(req, IFLA_BRPORT_LOCKED, link->network->locked);
+                        if (r < 0)
+                                return log_link_debug_errno(link, r, "Could not append IFLA_BRPORT_LOCKED attribute: %m");
+                }
+
                 if (link->network->priority != LINK_BRIDGE_PORT_PRIORITY_INVALID) {
                         r = sd_netlink_message_append_u16(req, IFLA_BRPORT_PRIORITY, link->network->priority);
                         if (r < 0)
-- 
2.46.1

